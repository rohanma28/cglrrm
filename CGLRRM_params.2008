Midlake Verbosity:	1
TS Data Verbosity:	1
General Verbosity:	1
#
Lakes to solve for: 	Smce
Month Length: Actual  
#
#  Do not round levels or flows during the primary routing calculations
Level Round: 		-99 
Flow Round: 		-99 
BOM Round: 			-99 
