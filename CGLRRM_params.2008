#
title1:         Plan 2012
title2:         Ensemble
#
St. M. Riv. Solution: Plan 2012
#
#  Use first 50% value for each month from "operation supply" matrix for
#  when checking Criterion B or C
P77A Compat Mode:	-1
#
OnlyOneOpen:		false
#  Assume file of error messages is in same directory
Message DataBase: 	messbase.txt
#
Sup Output Files:       M
Mhu Output Files:       M
StC Output Files:       M
Eri Output Files:       M
Write Erie Outflow: 	False
#
