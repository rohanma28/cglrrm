# Previous number of gates open and the last sturgeon year are required only for
# Plan 2012. 
Prev Sup Gates Open: 1
Last Sturgeon Year: 1979
#
# XXX Fix this...
#  initial condition: flow is the average of December flow from 1900 to 1999
#  Prev St. M. Riv. Flow will not used by all plans, but the input-checking module
#  expects to see it and refuses to run unless some value is provided.  Need to make 
#  the code smarter about this parameter so that it knows which plans require this
#  parameter, and move it from this common file into the input files specific to each
#  plan.  Until then, for Plan 2012, we just provide a value (average of December flow 
#  from 1900 to 1999, 2063 m3s, for some reason) and move forward. The previous flow
#  is required for Plan 77a.
Prev St. M. Riv. Flow:  2063 m3s
