#Extracts montly data to a 1 dimensional array
#Parameter "monthly" is a data set
getLinearMonthly<-function(monthly){
count<-1;
linearMonthly<-array()
for(row in 1:dim(monthly)[1]){
for(col in 2:13){
linearMonthly[count]<-as.numeric(monthly[row,..col])
count<-count+1
}
}
linearMonthly
}
#Extracts annual data to a 1 dimensional array
#Parameter "annual" is a data set
getLinearAnnually<-function(annual){
count=0;
linearAnnual<-array()
for(row in 1:dim(annual)[1]-1){
linearAnnual[count]=mean(as.numeric(annual[row,2:13]))
count=count+1;
}
sum=0;
rCount=2;
#While loop changed: was previously trying to compare NA values
print(tail(annual))
while(!is.na(annual[dim(annual)[1],..rCount])){
sum=sum+as.numeric(annual[dim(annual)[1],..rCount]);
rCount=rCount+1;
}
linearAnnual[dim(annual)[1]]=sum/(rCount-2);
linearAnnual
}
#the mean function wouldn't work so I made this instead.
average<-function(dat){
sum=0;
for(i in 1:length(dat)){
sum=sum+dat[i];
}
sum/(length(dat));
}
#Plots the data, as expected
#Parameter "data" is a data set
#Parameter "timescale" is a 1 dimensional array to be used on the x-axis
waterPlot<-function(monthly,annual,timescale){
old_monthly <- c(monthly[1:696], rep(NA, length(monthly) - 696))
old_annual <- c(annual[1:58], rep(NA, length(annual) - 58))
new_monthly <- c(rep(NA, 696), monthly[-(1:696)])
new_annual <- c(rep(NA, 58), annual[-(1:58)])
plot(timescale,old_monthly,type="p", xlab="Year"
,ylab="Water Surface Elevation (meters)", col="lightgrey",cex=0.3,pch=20,lwd=1,axes=FALSE,ylim = c(172, 184.5))
par(new=TRUE)
plot(timescale,new_monthly,type="p", xlab="Year"
,ylab="Water Surface Elevation (meters)", col="skyblue",cex=0.3,pch=20,lwd=1,axes=FALSE,ylim = c(172, 184.5))
par(new=TRUE)
currentYear=1859+length(annual);
plot(1860:currentYear,old_annual,axes=FALSE,col="black", cex=0.3,pch=20,ylim = c(172, 184.5),xlab="",ylab="")
par(new=TRUE)
plot(1860:currentYear,new_annual,axes=FALSE,col="darkblue", cex=0.3,pch=20,ylim = c(172, 184.5),xlab="",ylab="")
}
